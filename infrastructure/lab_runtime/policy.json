    "ip",
    "ping",
    "scp",
    "ftp",
    "sftp",
    "ssh",
    "telnet",
    "socat",
    "python3",
    "python",
    "python2",
    "perl",
    "ruby",
    "php",
    "node",
    "lua",
    "bash",
    "sh",
    "zsh",
    "dash",
    "ksh",
    "tcsh",
    "exec",
