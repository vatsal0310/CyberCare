  "max_command_length": 200,

  "notes": {
    "purpose": "Restrict lab users to password cracking tools only",
    "environment": "Isolated Docker container — no network access",
    "enforcement": "Enforced by backend/services/command_policy.py BEFORE docker exec. This file is the authoritative source loaded by command_policy.py.",
    "wordlist_path": "/wordlists/intermediate.txt",
    "hash_file_path": "/home/labuser/hash.txt"
  }
